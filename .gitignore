.DS_Store
__pycache__/
*.pyc
**/.git/
*.egg-info
*.swp
tags
node_modules

# Local working context (never commit).
.claude/
.agents/
skills-lock.json

# Internal project documents and source spreadsheets.
docs/
*.md
!README.md
# Frappe "Updated To A New Version" popup changelogs are shipped app files.
!apex_habitat/change_log/v0/*.md
!apex_habitat/change_log/v1/*.md

# Local/private office source files.
*.xlsx
*.xls
*.xlsm
*.csv
*.numbers
*.ods

# Translation CSV files are publishable because Arabic text belongs there.
!apex_habitat/apex_habitat/translations/
!apex_habitat/apex_habitat/translations/*.csv
!apex_habitat/translations/
!apex_habitat/translations/*.csv

# Environment, secrets, and local runtime files.
.env
.env.*
*.local
*.secret
*secret*
*.key
*.pem

# Build and packaging outputs.
build/
dist/
*.egg-info/

# Dead code archive.
archive/

# Local-only scratch scripts and reports (never commit).
*.command
*.applescript
flash_actions_report.json
