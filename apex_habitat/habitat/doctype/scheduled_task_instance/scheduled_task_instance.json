{
  "doctype": "DocType",
  "name": "Scheduled Task Instance",
  "module": "Habitat",
  "custom": 0,
  "issingle": 0,
  "istable": 0,
  "is_submittable": 1,
  "engine": "InnoDB",
  "description": "Submittable: one execution of a Scheduled Task Template. Auto-generated by the daily scheduler job.",
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_tab_overview",
      "fieldtype": "Tab Break",
      "label": "Overview",
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_sec_overview",
      "fieldtype": "Section Break",
      "label": "General Details",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "template",
      "fieldtype": "Link",
      "label": "Template",
      "options": "Scheduled Task Template",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "due_date",
      "fieldtype": "Date",
      "label": "Due Date",
      "reqd": 1,
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "completed_date",
      "fieldtype": "Date",
      "label": "Completed Date",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_overview_col",
      "fieldtype": "Column Break",
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned To (Employee)",
      "options": "Employee",
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "STI-.YYYY.-.####",
      "default": "STI-.YYYY.-.####",
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_sec_large_text",
      "fieldtype": "Section Break",
      "label": "Additional Information",
      "collapsible": 1,
      "idx": 9
    },
    {
      "doctype": "DocField",
      "fieldname": "completion_notes",
      "fieldtype": "Small Text",
      "label": "Completion Notes",
      "idx": 10
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_tab_system",
      "fieldtype": "Tab Break",
      "label": "System Info",
      "idx": 11
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_sec_system",
      "fieldtype": "Section Break",
      "label": "Administrative Details",
      "idx": 12
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "fieldtype": "Link",
      "label": "Building",
      "options": "Accommodation Building",
      "fetch_from": "template.building",
      "read_only": 1,
      "idx": 13
    },
    {
      "doctype": "DocField",
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nIn Progress\nCompleted\nOverdue\nCancelled",
      "default": "Open",
      "read_only": 1,
      "idx": 14
    },
    {
      "doctype": "DocField",
      "fieldname": "scheduled_task_instance_system_col",
      "fieldtype": "Column Break",
      "idx": 15
    },
    {
      "doctype": "DocField",
      "fieldname": "cancellation_reason",
      "fieldtype": "Small Text",
      "label": "Cancellation Reason",
      "read_only": 1,
      "idx": 16
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    }
  ]
}
