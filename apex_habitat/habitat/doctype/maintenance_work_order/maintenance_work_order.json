{
  "doctype": "DocType",
  "name": "Maintenance Work Order",
  "module": "Habitat",
  "custom": 0,
  "issingle": 0,
  "istable": 0,
  "is_submittable": 1,
  "engine": "InnoDB",
  "description": "Submittable: formal work order derived from a Maintenance Request.",
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_tab_overview",
      "fieldtype": "Tab Break",
      "label": "Overview",
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_sec_overview",
      "fieldtype": "Section Break",
      "label": "General Details",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_request",
      "fieldtype": "Link",
      "label": "Maintenance Request",
      "options": "Maintenance Request",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned To (Employee)",
      "options": "Employee",
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "planned_start_date",
      "fieldtype": "Date",
      "label": "Planned Start Date",
      "reqd": 1,
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "planned_end_date",
      "fieldtype": "Date",
      "label": "Planned End Date",
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "actual_start_date",
      "fieldtype": "Date",
      "label": "Actual Start Date",
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_overview_col",
      "fieldtype": "Column Break",
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "actual_end_date",
      "fieldtype": "Date",
      "label": "Actual End Date",
      "idx": 9
    },
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "MWO-.YYYY.-.####",
      "default": "MWO-.YYYY.-.####",
      "idx": 10
    },
    {
      "doctype": "DocField",
      "fieldname": "total_procurement_cost_sar",
      "fieldtype": "Currency",
      "label": "Total Procurement Cost (SAR)",
      "read_only": 1,
      "idx": 11
    },
    {
      "doctype": "DocField",
      "fieldname": "subcontractor_service_order",
      "fieldtype": "Link",
      "label": "Subcontractor Service Order",
      "options": "Subcontractor Service Order",
      "idx": 12
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_sec_primary_large_text",
      "fieldtype": "Section Break",
      "label": "Detailed Description",
      "idx": 13
    },
    {
      "doctype": "DocField",
      "fieldname": "work_description",
      "fieldtype": "Text Editor",
      "label": "Work Description",
      "reqd": 1,
      "idx": 14
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_sec_large_text",
      "fieldtype": "Section Break",
      "label": "Additional Information",
      "collapsible": 1,
      "idx": 15
    },
    {
      "doctype": "DocField",
      "fieldname": "completion_notes",
      "fieldtype": "Small Text",
      "label": "Completion Notes",
      "idx": 16
    },
    {
      "doctype": "DocField",
      "fieldname": "completion_photo",
      "fieldtype": "Attach Image",
      "label": "Completion Photo",
      "description": "Photo evidence that maintenance work was completed. Required before closing.",
      "idx": 17
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_tab_tables",
      "fieldtype": "Tab Break",
      "label": "Related Tables",
      "idx": 18
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_sec_table_procurement_items",
      "fieldtype": "Section Break",
      "label": "Procurement Items",
      "idx": 19
    },
    {
      "doctype": "DocField",
      "fieldname": "procurement_items",
      "fieldtype": "Table",
      "label": "Procurement Items",
      "options": "Maintenance Procurement Item",
      "idx": 20
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_tab_system",
      "fieldtype": "Tab Break",
      "label": "System Info",
      "idx": 21
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_sec_system",
      "fieldtype": "Section Break",
      "label": "Administrative Details",
      "idx": 22
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "fieldtype": "Link",
      "label": "Building",
      "options": "Accommodation Building",
      "fetch_from": "maintenance_request.building",
      "read_only": 1,
      "idx": 23
    },
    {
      "doctype": "DocField",
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nPlanned\nIn Progress\nCompleted\nCancelled",
      "default": "Draft",
      "read_only": 1,
      "idx": 24
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_work_order_system_col",
      "fieldtype": "Column Break",
      "idx": 25
    },
    {
      "doctype": "DocField",
      "fieldname": "cancellation_reason",
      "fieldtype": "Small Text",
      "label": "Cancellation Reason",
      "read_only": 1,
      "idx": 26
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1
    }
  ]
}
