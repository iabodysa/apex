{
  "doctype": "DocType",
  "name": "Cleaning Log",
  "module": "Habitat",
  "custom": 0,
  "istable": 0,
  "engine": "InnoDB",
  "is_submittable": 0,
  "track_changes": 0,
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "description": "Daily cleaning record per building. Not submittable — operational log only.",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "cleaning_log_sec_main",
      "fieldtype": "Section Break",
      "label": "Information",
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "CLEAN-.YYYY.-.####",
      "default": "CLEAN-.YYYY.-.####",
      "reqd": 1,
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "fieldtype": "Link",
      "label": "Building",
      "options": "Accommodation Building",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "cleaning_date",
      "fieldtype": "Date",
      "label": "Cleaning Date",
      "reqd": 1,
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "cleaned_by",
      "fieldtype": "Data",
      "label": "Cleaned By (Name)",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "cleaning_log_col_main",
      "fieldtype": "Column Break",
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "room_details",
      "fieldtype": "Table",
      "label": "Room Cleaning Details",
      "options": "Cleaning Log Room Detail",
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "supervisor_approved",
      "fieldtype": "Check",
      "label": "Approved by Supervisor",
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "approver",
      "fieldtype": "Link",
      "label": "Approved By",
      "options": "User",
      "depends_on": "eval:doc.supervisor_approved==1",
      "idx": 9
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1,
      "share": 1,
      "idx": 1
    },
    {
      "doctype": "DocPerm",
      "role": "Accommodation Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "idx": 2
    },
    {
      "doctype": "DocPerm",
      "role": "Resident Supervisor",
      "read": 1,
      "write": 1,
      "create": 1,
      "idx": 3
    }
  ]
}
