{
 "doctype": "DocType",
 "name": "Cleaning Log",
 "module": "Habitat",
 "custom": 0,
 "istable": 0,
 "engine": "InnoDB",
 "is_submittable": 0,
 "track_changes": 0,
 "autoname": "naming_series:",
 "naming_rule": "By \"Naming Series\" field",
 "sort_field": "modified",
 "sort_order": "DESC",
 "description": "Daily cleaning record per building with worker accountability and evidence controls.",
 "fields": [
  {
   "doctype": "DocField",
   "fieldname": "cleaning_log_tab_details",
   "fieldtype": "Tab Break",
   "label": "Details",
   "idx": 1
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaning_log_sec_details",
   "fieldtype": "Section Break",
   "label": "Information",
   "idx": 2
  },
  {
   "doctype": "DocField",
   "fieldname": "building",
   "fieldtype": "Link",
   "label": "Building",
   "options": "Accommodation Building",
   "reqd": 1,
   "idx": 3
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaning_date",
   "fieldtype": "Date",
   "label": "Cleaning Date",
   "reqd": 1,
   "idx": 4
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaner_type",
   "fieldtype": "Select",
   "label": "Cleaner Type",
   "options": "Internal Employee\nSubcontractor\nExternal Worker",
   "default": "Internal Employee",
   "idx": 5
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaner_employee",
   "fieldtype": "Link",
   "label": "Cleaner (Employee)",
   "options": "Employee",
   "depends_on": "eval:doc.cleaner_type=='Internal Employee'",
   "idx": 6
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaned_by",
   "fieldtype": "Data",
   "label": "Cleaner Name",
   "description": "For Subcontractor or External Worker when Employee link is not available.",
   "depends_on": "eval:doc.cleaner_type!='Internal Employee'",
   "idx": 7
  },
  {
   "doctype": "DocField",
   "fieldname": "subcontractor_service_order",
   "fieldtype": "Link",
   "label": "Subcontractor Service Order",
   "options": "Subcontractor Service Order",
   "depends_on": "eval:doc.cleaner_type=='Subcontractor'",
   "idx": 8
  },
  {
   "doctype": "DocField",
   "fieldname": "scheduled_task_instance",
   "fieldtype": "Link",
   "label": "Scheduled Task Instance",
   "options": "Scheduled Task Instance",
   "idx": 9
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaning_log_details_col",
   "fieldtype": "Column Break",
   "idx": 10
  },
  {
   "doctype": "DocField",
   "fieldname": "supervisor_approved",
   "fieldtype": "Check",
   "label": "Approved by Supervisor",
   "idx": 11
  },
  {
   "doctype": "DocField",
   "fieldname": "approver",
   "fieldtype": "Link",
   "label": "Approved By",
   "options": "User",
   "depends_on": "eval:doc.supervisor_approved==1",
   "idx": 12
  },
  {
   "doctype": "DocField",
   "fieldname": "supervisor_rating",
   "fieldtype": "Select",
   "label": "Supervisor Rating",
   "options": "\nSatisfactory\nNeeds Improvement\nUnsatisfactory",
   "depends_on": "eval:doc.supervisor_approved==1",
   "idx": 13
  },
  {
   "doctype": "DocField",
   "fieldname": "missed_cleaning",
   "fieldtype": "Check",
   "label": "Missed Cleaning",
   "idx": 14
  },
  {
   "doctype": "DocField",
   "fieldname": "missed_reason",
   "fieldtype": "Data",
   "label": "Missed Reason",
   "depends_on": "eval:doc.missed_cleaning==1",
   "idx": 15
  },
  {
   "doctype": "DocField",
   "fieldname": "rework_required",
   "fieldtype": "Check",
   "label": "Rework Required",
   "idx": 16
  },
  {
   "doctype": "DocField",
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "CLEAN-.YYYY.-.####",
   "default": "CLEAN-.YYYY.-.####",
   "reqd": 1,
   "idx": 17,
   "hidden": 1
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaning_log_sec_evidence",
   "fieldtype": "Section Break",
   "label": "Evidence",
   "idx": 18
  },
  {
   "doctype": "DocField",
   "fieldname": "evidence_photo",
   "fieldtype": "Attach Image",
   "label": "Evidence Photo",
   "idx": 19
  },
  {
   "doctype": "DocField",
   "fieldname": "evidence_notes",
   "fieldtype": "Small Text",
   "label": "Evidence Notes",
   "idx": 20
  },
  {
   "doctype": "DocField",
   "fieldname": "cleaning_log_sec_table_room_details",
   "fieldtype": "Section Break",
   "label": "Room Cleaning Details",
   "idx": 21
  },
  {
   "doctype": "DocField",
   "fieldname": "room_details",
   "fieldtype": "Table",
   "label": "Room Cleaning Details",
   "options": "Cleaning Log Room Detail",
   "idx": 22
  }
 ],
 "permissions": [
  {
   "doctype": "DocPerm",
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "report": 1,
   "export": 1,
   "print": 1,
   "email": 1,
   "share": 1,
   "idx": 1
  },
  {
   "doctype": "DocPerm",
   "role": "Accommodation Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "idx": 2
  },
  {
   "doctype": "DocPerm",
   "role": "Resident Supervisor",
   "read": 1,
   "write": 1,
   "create": 1,
   "idx": 3
  }
 ]
}
