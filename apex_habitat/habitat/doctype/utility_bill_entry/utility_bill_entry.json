{
 "doctype": "DocType",
 "name": "Utility Bill Entry",
 "module": "Habitat",
 "custom": 0,
 "istable": 0,
 "is_submittable": 1,
 "engine": "InnoDB",
 "track_changes": 1,
 "autoname": "naming_series:",
 "naming_rule": "By \"Naming Series\" field",
 "sort_field": "modified",
