  },
  {
   "doctype": "DocPerm",
   "role": "Accommodation Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1,
   "idx": 2
  },
  {
   "doctype": "DocPerm",
   "role": "Finance Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1,
   "cancel": 1,
   "idx": 3
  }
 ]
}
