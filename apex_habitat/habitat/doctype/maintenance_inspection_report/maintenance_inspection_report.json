   "read_only": 1,
   "idx": 18
  }
 ],
 "permissions": [
  {
   "doctype": "DocPerm",
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1
  }
 ]
}
