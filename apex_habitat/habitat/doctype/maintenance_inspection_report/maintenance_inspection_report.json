   "collapsible": 1,
   "idx": 11
  },
  {
   "doctype": "DocField",
   "fieldname": "remarks",
   "fieldtype": "Small Text",
   "label": "Remarks",
   "idx": 12
  },
  {
   "doctype": "DocField",
   "fieldname": "maintenance_inspection_report_tab_tables",
   "fieldtype": "Tab Break",
   "label": "Related Tables",
   "idx": 13
  },
  {
   "doctype": "DocField",
   "fieldname": "maintenance_inspection_report_sec_table_findings",
   "fieldtype": "Section Break",
