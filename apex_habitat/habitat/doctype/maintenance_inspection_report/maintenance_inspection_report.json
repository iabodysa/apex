{
 "doctype": "DocType",
 "name": "Maintenance Inspection Report",
 "module": "Habitat",
 "custom": 0,
 "issingle": 0,
 "istable": 0,
 "is_submittable": 1,
 "engine": "InnoDB",
 "description": "Submittable: official on-site maintenance inspection record.",
