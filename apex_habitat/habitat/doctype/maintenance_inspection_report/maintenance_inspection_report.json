  },
  {
   "doctype": "DocField",
   "fieldname": "maintenance_inspection_report_sec_overview",
   "fieldtype": "Section Break",
   "label": "General Details",
   "idx": 2
  },
  {
   "doctype": "DocField",
   "fieldname": "inspection_date",
   "fieldtype": "Date",
   "label": "Inspection Date",
   "reqd": 1,
   "idx": 3
  },
  {
   "doctype": "DocField",
   "fieldname": "building",
   "fieldtype": "Link",
   "label": "Building",
   "options": "Accommodation Building",
   "reqd": 1,
   "idx": 4
  },
  {
   "doctype": "DocField",
   "fieldname": "inspector",
   "fieldtype": "Link",
   "label": "Inspector (Employee)",
   "options": "Employee",
   "reqd": 1,
   "idx": 5
  },
  {
   "doctype": "DocField",
   "fieldname": "maintenance_work_order",
   "fieldtype": "Link",
   "label": "Maintenance Work Order",
   "options": "Maintenance Work Order",
   "idx": 6
  },
  {
   "doctype": "DocField",
   "fieldname": "maintenance_inspection_report_overview_col",
   "fieldtype": "Column Break",
   "idx": 7
  },
  {
   "doctype": "DocField",
   "fieldname": "inspection_type",
   "fieldtype": "Select",
   "label": "Inspection Type",
   "options": "Pre-Work\nPost-Work\nPeriodic\nEmergency",
   "default": "Post-Work",
   "idx": 8
  },
  {
   "doctype": "DocField",
   "fieldname": "overall_result",
   "fieldtype": "Select",
   "label": "Overall Result",
   "options": "Pass\nPass with Observations\nFail",
   "default": "Pass",
   "idx": 9
  },
  {
   "doctype": "DocField",
   "fieldname": "naming_series",
