{
  "doctype": "DocType",
  "name": "Operational Depreciation Policy",
  "module": "Habitat",
  "custom": 0,
  "issingle": 0,
  "istable": 0,
  "engine": "InnoDB",
  "description": "Master: useful life and write-down schedule for custody article categories. Operational only, no GL.",
  "autoname": "field:policy_name",
  "naming_rule": "By fieldname",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "policy_name",
      "fieldtype": "Data",
      "label": "Policy Name",
      "reqd": 1,
      "unique": 1,
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "asset_category",
      "fieldtype": "Link",
      "label": "Asset Category",
      "options": "Custody Asset Category",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "useful_life_years",
      "fieldtype": "Int",
      "label": "Useful Life (Years)",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "depreciation_method",
      "fieldtype": "Select",
      "label": "Method",
      "options": "Straight Line\nDeclining Balance",
      "default": "Straight Line",
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "residual_value_pct",
      "fieldtype": "Percent",
      "label": "Residual Value (%)",
      "default": "0",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes",
      "idx": 6
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    }
  ]
}
