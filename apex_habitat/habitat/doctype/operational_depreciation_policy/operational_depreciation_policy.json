    {
      "doctype": "DocField",
      "fieldname": "operational_depreciation_policy_sec_details",
      "fieldtype": "Section Break",
      "label": "Information",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "policy_name",
