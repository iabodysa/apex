{
  "doctype": "DocType",
  "name": "Operational Depreciation Policy",
  "module": "Habitat",
  "custom": 0,
  "issingle": 0,
  "istable": 0,
  "engine": "InnoDB",
  "description": "Master: useful life and write-down schedule for custody article categories. Operational only, no GL.",
