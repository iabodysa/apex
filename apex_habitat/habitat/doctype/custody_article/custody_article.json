   "label": "Information",
   "idx": 2
  },
  {
   "doctype": "DocField",
   "fieldname": "article_name",
   "fieldtype": "Data",
   "label": "Article Name",
   "reqd": 1,
   "idx": 3
  },
  {
   "doctype": "DocField",
   "fieldname": "category",
   "fieldtype": "Link",
   "label": "Category",
   "options": "Custody Asset Category",
   "reqd": 1,
   "idx": 4
  },
  {
   "doctype": "DocField",
   "fieldname": "unit_of_measure",
