  },
  {
   "doctype": "DocField",
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "CUST-ART-.####",
   "default": "CUST-ART-.####",
   "idx": 9,
   "hidden": 1
  },
  {
   "doctype": "DocField",
   "fieldname": "standard_unit_cost_sar",
