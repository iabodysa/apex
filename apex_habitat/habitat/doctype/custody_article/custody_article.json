  },
  {
   "role": "Accommodation Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "doctype": "DocPerm",
   "idx": 2
  },
  {
   "role": "Resident Supervisor",
   "read": 1,
   "write": 1,
   "create": 1,
   "doctype": "DocPerm",
   "idx": 3
  }
 ]
