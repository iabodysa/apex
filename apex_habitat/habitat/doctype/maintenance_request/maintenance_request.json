{
  "doctype": "DocType",
  "name": "Maintenance Request",
  "module": "Habitat",
  "custom": 0,
  "istable": 0,
  "is_submittable": 1,
  "engine": "InnoDB",
  "track_changes": 1,
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "description": "Room-level maintenance ticket. Confirmed naming pattern: MAINT-2026-00027. Can be auto-generated from Safety Inspection Report.",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "MAINT-.YYYY.-.#####",
      "default": "MAINT-.YYYY.-.#####",
      "reqd": 1,
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "fieldtype": "Link",
      "label": "Building",
      "options": "Accommodation Building",
      "reqd": 1,
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "room",
      "fieldtype": "Link",
      "label": "Room",
      "options": "Accommodation Room",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "bed",
      "fieldtype": "Link",
      "label": "Bed (if bed-specific)",
      "options": "Accommodation Bed",
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "source_inspection",
      "fieldtype": "Link",
      "label": "Source Inspection Report",
      "options": "Safety Inspection Report",
      "description": "Populated when auto-generated from FSI",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "reported_by",
      "fieldtype": "Link",
      "label": "Reported By",
      "options": "User",
      "reqd": 1,
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "issue_type",
      "fieldtype": "Select",
      "label": "Issue Type",
      "options": "Electrical\nPlumbing\nFurniture\nAir Conditioning\nFire Safety\nPest Control\nStructural\nOther",
      "reqd": 1,
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "issue_description",
      "fieldtype": "Small Text",
      "label": "Issue Description",
      "reqd": 1,
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "priority",
      "fieldtype": "Select",
      "label": "Priority",
      "options": "Low\nMedium\nHigh\nCritical",
      "default": "Medium",
      "idx": 9
    },
    {
      "doctype": "DocField",
      "fieldname": "assigned_to",
      "fieldtype": "Link",
      "label": "Assigned To",
      "options": "User",
      "idx": 10
    },
    {
      "doctype": "DocField",
      "fieldname": "resolution_notes",
      "fieldtype": "Small Text",
      "label": "Resolution Notes",
      "idx": 11
    },
    {
      "doctype": "DocField",
      "fieldname": "cost_of_repair",
      "fieldtype": "Currency",
      "label": "Cost of Repair (SAR)",
      "idx": 12
    },
    {
      "doctype": "DocField",
      "fieldname": "cost_center",
      "fieldtype": "Link",
      "label": "Cost Center",
      "options": "Cost Center",
      "description": "Auto-fetched from Building",
      "idx": 13
    },
    {
      "doctype": "DocField",
      "fieldname": "requires_procurement",
      "fieldtype": "Check",
      "label": "Requires Procurement",
      "idx": 14
    },
    {
      "doctype": "DocField",
      "fieldname": "procurement_items",
      "fieldtype": "Table",
      "label": "Procurement Items Required",
      "options": "Maintenance Procurement Item",
      "depends_on": "eval:doc.requires_procurement==1",
      "idx": 15
    },
    {
      "doctype": "DocField",
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Open\nAssigned\nIn Progress\nResolved\nClosed\nReopened",
      "default": "Open",
      "idx": 16
    },
    {
      "doctype": "DocField",
      "fieldname": "related_facility_asset",
      "fieldtype": "Link",
      "label": "Related Facility Asset",
      "options": "Facility Asset",
      "description": "Use when the issue concerns a specific facility asset (e.g., CCTV camera, fire alarm panel)",
      "idx": 17
    },
    {
      "doctype": "DocField",
      "fieldname": "subcontractor_dispatched",
      "fieldtype": "Link",
      "label": "Subcontractor Dispatched",
      "options": "Subcontractor Service Order",
      "description": "Set when a subcontractor visit is created from this request",
      "idx": 18
    },
    {
      "doctype": "DocField",
      "fieldname": "section_asset_link",
      "fieldtype": "Section Break",
      "label": "Asset Identification",
      "idx": 19
    },
    {
      "doctype": "DocField",
      "fieldname": "target_asset",
      "fieldtype": "Link",
      "label": "Target ERPNext Asset",
      "options": "Asset",
      "description": "Specific Fixed Asset this request concerns (e.g., AC-001, BED-014). Enables full maintenance history per asset.",
      "idx": 20
    },
    {
      "doctype": "DocField",
      "fieldname": "target_asset_name",
      "fieldtype": "Data",
      "label": "Asset Name",
      "fetch_from": "target_asset.asset_name",
      "read_only": 1,
      "idx": 21
    },
    {
      "doctype": "DocField",
      "fieldname": "target_asset_category",
      "fieldtype": "Data",
      "label": "Asset Category",
      "fetch_from": "target_asset.asset_category",
      "read_only": 1,
      "idx": 22
    },
    {
      "doctype": "DocField",
      "fieldname": "target_asset_location",
      "fieldtype": "Data",
      "label": "Asset Location",
      "fetch_from": "target_asset.location",
      "read_only": 1,
      "idx": 23
    },
    {
      "doctype": "DocField",
      "fieldname": "is_logged_to_asset_history",
      "fieldtype": "Check",
      "label": "Logged to Asset Maintenance History",
      "read_only": 1,
      "description": "Set to 1 by on_update hook when status becomes \u0027Resolved\u0027 and target_asset is set",
      "idx": 24
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1,
      "share": 1,
      "idx": 1
    },
    {
      "doctype": "DocPerm",
      "role": "Accommodation Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "idx": 2
    },
    {
      "doctype": "DocPerm",
      "role": "Resident Supervisor",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "idx": 3
    }
  ]
}
