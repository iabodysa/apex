{
  "doctype": "DocType",
  "name": "Safety Inspection Finding Item",
  "module": "Habitat",
  "custom": 0,
  "istable": 1,
  "engine": "InnoDB",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "finding_type",
