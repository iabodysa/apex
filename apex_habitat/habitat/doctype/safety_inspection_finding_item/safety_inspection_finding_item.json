      "label": "Finding Type",
      "options": "Fire Panel Fault\nSmoke Detector Fault\nNo Emergency Signage\nNo First Aid Kit\nExit Blocked\nElectrical Hazard\nStructural Risk\nOther",
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "location_description",
