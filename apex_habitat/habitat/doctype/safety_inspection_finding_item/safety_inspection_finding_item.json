      "label": "Location in Building",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "severity",
      "fieldtype": "Select",
      "label": "Severity",
      "options": "Low\nMedium\nHigh\nCritical",
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "photo",
      "fieldtype": "Attach Image",
      "label": "Photo Evidence",
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "escalate_same_day",
      "fieldtype": "Check",
