{
  "doctype": "DocType",
  "name": "Safety Inspection Report",
  "module": "Habitat",
  "custom": 0,
  "istable": 0,
  "engine": "InnoDB",
  "is_submittable": 1,
  "track_changes": 1,
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "description": "Weekly field inspection. Confirmed pattern: FSI-2026-00027, FSI-2026-00028. Auto-generates Maintenance Requests on submit.",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Series",
      "options": "FSI-.YYYY.-.#####",
      "default": "FSI-.YYYY.-.#####",
      "reqd": 1,
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "fieldtype": "Link",
      "label": "Building",
      "options": "Accommodation Building",
      "reqd": 1,
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "inspection_date",
      "fieldtype": "Date",
      "label": "Inspection Date",
      "reqd": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "inspector",
      "fieldtype": "Link",
      "label": "Inspector",
      "options": "User",
      "reqd": 1,
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "safety_section_clear",
      "fieldtype": "Check",
      "label": "Safety Section \u2014 No Issues",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "safety_findings",
      "fieldtype": "Table",
      "label": "Safety Findings",
      "options": "Safety Inspection Finding Item",
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "maintenance_findings",
      "fieldtype": "Table",
      "label": "Maintenance Findings",
      "options": "Maintenance Inspection Finding Item",
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "previous_repairs_confirmed",
      "fieldtype": "Check",
      "label": "Previous Repairs Confirmed",
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "previous_repair_notes",
      "fieldtype": "Small Text",
      "label": "Previous Repair Confirmation Details",
      "idx": 9
    },
    {
      "doctype": "DocField",
      "fieldname": "linked_maintenance_requests",
      "fieldtype": "Table",
      "label": "Generated Maintenance Requests",
      "options": "Linked Maintenance Request Item",
      "read_only": 1,
      "idx": 10
    },
    {
      "doctype": "DocField",
      "fieldname": "submitted_to",
      "fieldtype": "Small Text",
      "label": "Submitted To (Recipients)",
      "read_only": 1,
      "description": "Admin Manager, Operations Director, General Manager",
      "idx": 11
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1,
      "share": 1,
      "idx": 1
    },
    {
      "doctype": "DocPerm",
      "role": "Accommodation Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1,
      "amend": 1,
      "idx": 2
    },
    {
      "doctype": "DocPerm",
      "role": "Resident Supervisor",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "idx": 3
    }
  ]
}