{
  "doctype": "DocType",
  "name": "Accommodation Room",
  "module": "Habitat",
  "custom": 0,
  "istable": 0,
  "engine": "InnoDB",
  "track_changes": 1,
  "autoname": "naming_series:",
  "naming_rule": "By \"Naming Series\" field",
  "sort_field": "modified",
  "sort_order": "DESC",
  "fields": [
    {
      "doctype": "DocField",
      "fieldname": "accommodation_room_tab_details",
      "fieldtype": "Tab Break",
      "label": "Details",
      "idx": 1
    },
    {
      "doctype": "DocField",
      "fieldname": "accommodation_room_sec_details",
      "fieldtype": "Section Break",
      "label": "Information",
      "idx": 2
    },
    {
      "doctype": "DocField",
      "fieldname": "building",
      "label": "Building",
      "fieldtype": "Link",
      "options": "Accommodation Building",
      "reqd": 1,
      "in_list_view": 1,
      "idx": 3
    },
    {
      "doctype": "DocField",
      "fieldname": "room_number",
      "label": "Room Number",
      "fieldtype": "Data",
      "reqd": 1,
      "in_list_view": 1,
      "idx": 4
    },
    {
      "doctype": "DocField",
      "fieldname": "floor",
      "label": "Floor",
      "fieldtype": "Int",
      "idx": 5
    },
    {
      "doctype": "DocField",
      "fieldname": "room_type",
      "label": "Room Type",
      "fieldtype": "Select",
      "options": "Standard\nSupervisor\nIsolation\nStorage",
      "default": "Standard",
      "idx": 6
    },
    {
      "doctype": "DocField",
      "fieldname": "accommodation_room_details_col",
      "fieldtype": "Column Break",
      "idx": 7
    },
    {
      "doctype": "DocField",
      "fieldname": "bed_capacity",
      "label": "Bed Capacity",
      "fieldtype": "Int",
      "reqd": 1,
      "idx": 8
    },
    {
      "doctype": "DocField",
      "fieldname": "status",
      "label": "Status",
      "fieldtype": "Select",
      "options": "Available\nPartially Occupied\nFull\nUnder Maintenance",
      "default": "Available",
      "in_list_view": 1,
      "idx": 9
    },
    {
      "doctype": "DocField",
      "fieldname": "naming_series",
      "label": "Series",
      "fieldtype": "Select",
      "options": "ROOM-.####",
      "default": "ROOM-.####",
      "reqd": 1,
      "hidden": 1,
      "idx": 10
    },
    {
      "doctype": "DocField",
      "fieldname": "current_occupancy",
      "label": "Current Occupancy",
      "fieldtype": "Int",
      "read_only": 1,
      "idx": 11
    },
    {
      "doctype": "DocField",
      "fieldname": "accommodation_room_sec_inventory",
      "fieldtype": "Section Break",
      "label": "Supervisor Inventory",
      "collapsible": 1,
      "idx": 12
    },
    {
      "doctype": "DocField",
      "fieldname": "readiness_status",
      "label": "Readiness Status",
      "fieldtype": "Select",
      "options": "Unknown\nReady\nNeeds Cleaning\nNeeds Repair\nOut of Service",
      "default": "Unknown",
      "in_list_view": 0,
      "idx": 13
    },
    {
      "doctype": "DocField",
      "fieldname": "last_inventory_date",
      "label": "Last Inventory Date",
      "fieldtype": "Date",
      "read_only": 1,
      "idx": 14
    },
    {
      "doctype": "DocField",
      "fieldname": "accommodation_room_inventory_col",
      "fieldtype": "Column Break",
      "idx": 15
    },
    {
      "doctype": "DocField",
      "fieldname": "inventory_notes",
      "label": "Inventory Notes",
      "fieldtype": "Small Text",
      "idx": 16
    }
  ],
  "permissions": [
    {
      "doctype": "DocPerm",
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "report": 1,
      "export": 1,
      "print": 1,
      "email": 1,
      "share": 1,
      "idx": 1
    },
    {
      "doctype": "DocPerm",
      "role": "Accommodation Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "idx": 2
    },
    {
      "doctype": "DocPerm",
      "role": "Resident Supervisor",
      "read": 1,
      "idx": 3
    }
  ]
}
